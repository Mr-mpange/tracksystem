# Supabase (required for app + GitHub Pages deploy secrets)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Public app URL (login links, invites) — use your GitHub Pages or production URL
VITE_SITE_URL=https://mr-mpange.github.io/tracksystem
SITE_URL=https://mr-mpange.github.io/tracksystem

# Set automatically by build:pages / CI — do not set locally unless testing static build
# VITE_GITHUB_PAGES=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (invites, USSD callback display)
SITE_URL=http://localhost:5173

# Africa's Talking — SMS + USSD
# https://account.africastalking.com → Sandbox or Live
# Sandbox SMS uses api.sandbox.africastalking.com (USSD only needs callback URL, no API key)
AT_USERNAME=sandbox
AT_API_KEY=your_sandbox_api_key

# Your USSD service code from AT dashboard (shown on Schedules page)
AT_USSD_CODE=*384*12345#

# Live SMS only — approved sender ID
# AT_FROM_SHORTCODE=
